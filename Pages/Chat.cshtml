@page "{name}"
@model PingChat.Pages.ChatModel
@{
    ViewData["Title"] = $"Chat - {Model.ChannelName}";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <h1 class="mb-1"># @Model.ChannelName</h1>
                <span class="badge bg-secondary">@Model.ChannelType</span>
            </div>
            <p class="text-muted mb-0">@Model.ChannelDescription</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Channels">Back to Channels</a>
    </div>

    <div class="row mt-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Messages</strong>
                    <span class="text-muted small">@Model.Messages.Count message(s)</span>
                </div>

                <div id="messagesContainer" class="card-body p-0 bg-light" style="height: 420px; overflow-y: auto;">
                    <ul id="messagesList" class="list-group list-group-flush">
                        @if (Model.Messages.Any())
                        {
                            @foreach (var message in Model.Messages)
                            {
                                <li class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div class="flex-grow-1">
                                            <strong>@message.Author</strong><br />
                                            <small class="text-muted">@message.Time</small><br />
                                            <span>@message.Text</span>
                                        </div>

                                        @if (message.CanDelete)
                                        {
                                            <form method="post" asp-page-handler="Delete" asp-route-name="@Model.ChannelName">
                                                <input type="hidden" name="messageId" value="@message.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                            </form>
                                        }
                                    </div>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-center py-4 text-muted">
                                No messages yet. Start the conversation.
                            </li>
                        }
                    </ul>
                </div>

                <div class="card-footer">
                    <input type="hidden" id="channelName" value="@Model.ChannelName" />
                    <input type="hidden" id="currentUser" value="@(User.Identity?.Name ?? "Anonymous")" />

                    <form>
                        <label class="form-label" for="messageInput">New message</label>
                        <div class="input-group">
                            <input id="messageInput" type="text" class="form-control" placeholder="Type a message..." />
                            <button id="sendButton" type="button" class="btn btn-primary">Send</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="card shadow-sm">
                <div class="card-header">
                    <strong>Channel Details</strong>
                </div>
                <div class="card-body">
                    <p class="mb-2"><strong>Name:</strong> #@Model.ChannelName</p>
                    <p class="mb-2"><strong>Type:</strong> @Model.ChannelType</p>
                    <p class="mb-2"><strong>Description:</strong> @Model.ChannelDescription</p>
                    <p class="mb-0"><strong>Status:</strong> Live chat with SQLite persistence</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/chat.js"></script>
}
