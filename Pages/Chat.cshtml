@page "{name}"
@model PingChat.Pages.ChatModel
@{
    ViewData["Title"] = $"Chat - {Model.ChannelName}";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h1 class="mb-1"># @Model.ChannelName</h1>
            <p class="text-muted mb-0">Agency / client channel conversation</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Channels">Back to Channels</a>
    </div>

    <div class="row mt-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header">
                    <strong>Messages</strong>
                </div>
                <div class="card-body bg-light" style="min-height: 320px;">
                    <div class="mb-3">
                        <strong>Amanda</strong>
                        <div class="text-muted small">9:02 AM</div>
                        <div>Welcome to #@Model.ChannelName.</div>
                    </div>

                    <div class="mb-3">
                        <strong>Chris</strong>
                        <div class="text-muted small">9:04 AM</div>
                        <div>This is where our real-time SignalR chat will appear next.</div>
                    </div>

                    <div class="mb-3">
                        <strong>You</strong>
                        <div class="text-muted small">9:05 AM</div>
                        <div>Static page first. Real-time messaging after that.</div>
                    </div>
                </div>
                <div class="card-footer">
                    <form>
                        <label class="form-label">New message</label>
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Type a message..." />
                            <button type="button" class="btn btn-primary">Send</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="card shadow-sm">
                <div class="card-header">
                    <strong>Channel Details</strong>
                </div>
                <div class="card-body">
                    <p class="mb-2"><strong>Name:</strong> #@Model.ChannelName</p>
                    <p class="mb-2"><strong>Type:</strong> @Model.ChannelType</p>
                    <p class="mb-0"><strong>Status:</strong> Connected UI placeholder</p>
                </div>
            </div>
        </div>
    </div>
</div>
