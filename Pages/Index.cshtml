@page
@model IndexModel
@{
    ViewData["Title"] = "PingChat";
}

<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <h1 class="display-4 fw-bold">PingChat</h1>
            <p class="lead mt-3">
                Real-time agency and client project chat built with ASP.NET Core, Razor Pages, SignalR, and SQLite.
            </p>
            <p class="text-muted">
                PingChat is a lightweight collaboration app for internal agency communication and client-facing project rooms.
            </p>

            <div class="d-flex flex-wrap gap-2 mt-4">
                <a class="btn btn-primary btn-lg" asp-page="/Dashboard">Open Dashboard</a>
                <a class="btn btn-outline-secondary btn-lg" asp-page="/Channels">Browse Channels</a>
            </div>
        </div>

        <div class="col-lg-5 mt-5 mt-lg-0">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Current MVP Features</h2>
                    <ul class="mb-0">
                        <li>Identity-based login</li>
                        <li>Role-aware dashboard</li>
                        <li>Channel visibility rules</li>
                        <li>SignalR real-time messaging</li>
                        <li>SQLite message persistence</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
