@page
@model PingChat.Pages.ChannelsModel
@{
    ViewData["Title"] = "Channels";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h1 class="mb-1">Channels</h1>
            <p class="text-muted mb-0">
                Workspace: <strong>@Model.WorkspaceName</strong> · Role: <strong>@Model.CurrentUserRole</strong>
            </p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Dashboard">Back to Dashboard</a>
    </div>

    <div class="list-group mt-4">
        @foreach (var channel in Model.Channels)
        {
            <a asp-page="/Chat"
               asp-route-name="@channel.Slug"
               class="list-group-item list-group-item-action">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-semibold"># @channel.Slug</div>
                        <div class="text-muted small">@channel.Description</div>
                    </div>
                    <span class="badge @channel.BadgeClass rounded-pill">@channel.TypeLabel</span>
                </div>
            </a>
        }
    </div>
</div>
