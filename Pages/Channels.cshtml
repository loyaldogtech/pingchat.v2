@page
@model PingChat.Pages.ChannelsModel
@{
    ViewData["Title"] = "Channels";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Channels</h1>
        <a class="btn btn-outline-secondary" asp-page="/Dashboard">Back to Dashboard</a>
    </div>

    <p class="mt-3">Select a channel to start chatting.</p>

    <div class="list-group mt-3">
        @foreach (var channel in Model.Channels)
        {
            <a asp-page="/Chat"
               asp-route-name="@channel.Slug"
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                <span># @channel.Slug</span>
                <span class="badge @channel.BadgeClass rounded-pill">@channel.TypeLabel</span>
            </a>
        }
    </div>
</div>
