@page
@model PingChat.Pages.ChannelsModel
@{
    ViewData["Title"] = "Channels";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Channels</h1>
        <a class="btn btn-outline-secondary" asp-page="/Dashboard">Back to Dashboard</a>
    </div>

    <p class="mt-3">Select a channel to start chatting.</p>

    <div class="list-group mt-3">
        <a asp-page="/Chat" asp-route-name="general" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span># general</span>
            <span class="badge bg-primary rounded-pill">Agency + Client</span>
        </a>

        <a asp-page="/Chat" asp-route-name="internal" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span># internal</span>
            <span class="badge bg-dark rounded-pill">Agency Only</span>
        </a>

        <a asp-page="/Chat" asp-route-name="client-acme" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span># client-acme</span>
            <span class="badge bg-success rounded-pill">Client Channel</span>
        </a>

        <a asp-page="/Chat" asp-route-name="project-redesign" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span># project-redesign</span>
            <span class="badge bg-info text-dark rounded-pill">Project Room</span>
        </a>
    </div>
</div>
